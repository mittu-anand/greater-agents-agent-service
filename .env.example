# ── Provider: Gemini (Google AI Studio) ─────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your_google_ai_studio_key_here

# ── Provider: Groq (free, fast inference) ───────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# ── Default model (used when no llm is specified in the deploy request) ──────
# Gemini options:  gemini-1.5-flash  |  gemini-2.0-flash  |  gemini-1.5-pro
# Groq options:    groq/llama-3.3-70b-versatile  |  groq/mixtral-8x7b-32768
MODEL=groq/llama-3.3-70b-versatile

# ── MCP server SSE endpoint (optional — only needed if using MCP tools) ──────
MCP_SSE_URL=http://localhost:8080/mcp/sse

# ── Redis for persistent sessions (optional) ─────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── Port ─────────────────────────────────────────────────────────────────────
PORT=8001
